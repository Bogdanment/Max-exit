# Backend Production Environment
# Используйте переменные окружения для каждой платформы деплоя

PORT=5000
NODE_ENV=production

# Database (для локально)
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=exit_db

# ДЛЯ PRODUCTION - используйте DATABASE_URL вместо отдельных переменных:
# DATABASE_URL=postgresql://user:password@host:port/database

# JWT - ОБЯЗАТЕЛЬНО СМЕНИТЕ НА PRODUCTION!
JWT_SECRET=change-this-to-a-very-long-random-secret-key-minimum-32-characters

# Для Railway:
# DATABASE_URL будет установлен автоматически из переменной окружения
# JWT_SECRET должен быть установлен в Dashboard

# Для Heroku:
# DATABASE_URL будет установлен через Heroku PostgreSQL addon
# JWT_SECRET должен быть установлен через heroku config:set

# Для Render:
# DATABASE_URL будет установлен из PostgreSQL сервиса
# JWT_SECRET должен быть установлен в Environment переменных
