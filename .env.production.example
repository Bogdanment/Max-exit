# Frontend Production Environment
# Замените на ваш реальный API URL

# Для локального тестирования
VITE_API_URL=http://localhost:5000/api

# Для production на Railway
# VITE_API_URL=https://your-api-name.railway.app/api

# Для production на Heroku
# VITE_API_URL=https://your-app-name.herokuapp.com/api

# Для production на Render
# VITE_API_URL=https://your-api-name.onrender.com/api
